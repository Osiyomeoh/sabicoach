    "react": "18.3.1",
    "react-dom": "^18.3.1",
    "react-native": "^0.76.9",
    "react-native-safe-area-context": "4.12.0",
    "react-native-web": "^0.19.13"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@types/react": "~18.3.12",
    "typescript": "^5.7.2"
