{
  "buildCommand": "npm run export:web",
  "outputDirectory": "dist",
  "functions": {
    "api/signup.ts": { "runtime": "nodejs22.x" },
    "api/login.ts": { "runtime": "nodejs22.x" }
  },
  "rewrites": [
    { "source": "/app", "destination": "/app/index.html" },
    { "source": "/capture", "destination": "/capture.html" },
    { "source": "/journey", "destination": "/app/index.html" },
    { "source": "/demo", "destination": "/app/index.html" },
    { "source": "/", "destination": "/index.html" }
  ]
}
